# ──────────────────────────────────────────────────────────────────────────────
# BioLens Platform — Environment Variables
# Copy this file to .env and fill in the values for local development.
# In production these are injected at runtime from Azure Key Vault.
# ──────────────────────────────────────────────────────────────────────────────

# Firebase configuration
# Key Vault secret names: vite-firebase-api-key, vite-firebase-auth-domain, etc.
VITE_FIREBASE_API_KEY=AIzaSyB-1mTbCK3g6jDC47BF8Fqx3bfzEMx62LM
VITE_FIREBASE_AUTH_DOMAIN=biolens--platform.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=biolens--platform
VITE_FIREBASE_STORAGE_BUCKET=biolens--platform.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=709849991785
VITE_FIREBASE_APP_ID=1:709849991785:web:f940401f4ca047268ab0f8

# Feature flags
VITE_DEV_MODE=false
VITE_API_DEBUG=false

# ──────────────────────────────────────────────────────────────────────────────
# Azure Key Vault (runtime / Docker only — not used by Vite dev server)
# ──────────────────────────────────────────────────────────────────────────────

# Set to true to enable secret fetching via VM Managed Identity at container startup
USE_KEY_VAULT=false

# Name of the Azure Key Vault (e.g. biolens-kv-prod)
KEY_VAULT_NAME=biolens-kv

# Deployment environment label written into env-config.js
ENVIRONMENT=development

# Enable verbose logging in start_production.sh
DEBUG_MODE=false
